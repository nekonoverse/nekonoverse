services:
  postgresql:
    image: postgres:18-alpine
    restart: unless-stopped
    environment:
      POSTGRES_DB: nekonoverse
      POSTGRES_USER: nekonoverse
      POSTGRES_PASSWORD: ${DB_PASSWORD}
    volumes:
      - postgresql_data:/var/lib/postgresql
    ports:
      - "5432:5432"
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U nekonoverse"]
      interval: 10s
      timeout: 5s
      retries: 5

  valkey:
    image: valkey/valkey:8-alpine
    restart: unless-stopped
    volumes:
      - valkey_data:/data
    ports:
      - "6379:6379"
    healthcheck:
      test: ["CMD", "valkey-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5

  nekono3s:
    image: ghcr.io/nananek/nekono3s:latest
    restart: unless-stopped
    environment:
      S3_ACCESS_KEY_ID: ${S3_ACCESS_KEY_ID:-nekonoverse}
      S3_SECRET_ACCESS_KEY: ${S3_SECRET_ACCESS_KEY:-changeme-s3}
      S3_STORAGE_PATH: /data
      S3_REGION: us-east-1
      S3_XATTR_JCLOUDS_COMPAT: "true"
    volumes:
      - nekono3s_data:/data
    healthcheck:
      test: ["CMD", "python", "-c", "import socket; s=socket.create_connection(('localhost',8080),2); s.close()"]
      interval: 10s
      timeout: 5s
      retries: 3

  s3proxy-deliverer:
    image: ghcr.io/nananek/s3proxy-deliverer:latest
    restart: unless-stopped
    environment:
      STORAGE_ROOT: /data
    volumes:
      - nekono3s_data:/data:ro
    depends_on:
      nekono3s:
        condition: service_healthy

  app:
    build:
      context: ./backend
      dockerfile: Dockerfile
      target: dev
    restart: unless-stopped
    command: >
      sh -c "alembic upgrade head && uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload"
    environment:
      DATABASE_URL: postgresql+asyncpg://nekonoverse:${DB_PASSWORD}@postgresql:5432/nekonoverse
      VALKEY_URL: valkey://valkey:6379/0
      DOMAIN: ${DOMAIN:-localhost}
      SECRET_KEY: ${SECRET_KEY}
      DEBUG: ${DEBUG:-true}
      S3_ENDPOINT_URL: http://nekono3s:8080
      S3_ACCESS_KEY_ID: ${S3_ACCESS_KEY_ID:-nekonoverse}
      S3_SECRET_ACCESS_KEY: ${S3_SECRET_ACCESS_KEY:-changeme-s3}
      S3_BUCKET: ${S3_BUCKET:-nekonoverse}
      S3_REGION: us-east-1
    volumes:
      - ./backend:/app
    ports:
      - "8000:8000"
    depends_on:
      postgresql:
        condition: service_healthy
      valkey:
        condition: service_healthy
      nekono3s:
        condition: service_healthy

  worker:
    build:
      context: ./backend
      dockerfile: Dockerfile
      target: dev
    restart: unless-stopped
    command: python -m app.worker.main
    environment:
      DATABASE_URL: postgresql+asyncpg://nekonoverse:${DB_PASSWORD}@postgresql:5432/nekonoverse
      VALKEY_URL: valkey://valkey:6379/0
      DOMAIN: ${DOMAIN:-localhost}
      SECRET_KEY: ${SECRET_KEY}
      S3_ENDPOINT_URL: http://nekono3s:8080
      S3_ACCESS_KEY_ID: ${S3_ACCESS_KEY_ID:-nekonoverse}
      S3_SECRET_ACCESS_KEY: ${S3_SECRET_ACCESS_KEY:-changeme-s3}
      S3_BUCKET: ${S3_BUCKET:-nekonoverse}
      S3_REGION: us-east-1
    volumes:
      - ./backend:/app
    depends_on:
      postgresql:
        condition: service_healthy
      valkey:
        condition: service_healthy
      nekono3s:
        condition: service_healthy

  frontend:
    build:
      context: ./frontend
      dockerfile: Dockerfile
      target: dev
    restart: unless-stopped
    command: npx --yes vite dev --host 0.0.0.0 --port 3000
    environment:
      VITE_API_URL: ""
    volumes:
      - ./frontend:/app
      - /app/node_modules
    ports:
      - "3000:3000"

volumes:
  postgresql_data:
  valkey_data:
  nekono3s_data:
