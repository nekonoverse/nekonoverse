services:
  postgresql:
    image: postgres:17-alpine
    restart: unless-stopped
    environment:
      POSTGRES_DB: nekonoverse
      POSTGRES_USER: nekonoverse
      POSTGRES_PASSWORD: ${DB_PASSWORD}
    volumes:
      - postgresql_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U nekonoverse"]
      interval: 10s
      timeout: 5s
      retries: 5

  valkey:
    image: valkey/valkey:8-alpine
    restart: unless-stopped
    volumes:
      - valkey_data:/data
    healthcheck:
      test: ["CMD", "valkey-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5

  nekono3s:
    image: ghcr.io/nananek/nekono3s:latest
    restart: unless-stopped
    environment:
      S3_ACCESS_KEY_ID: ${S3_ACCESS_KEY_ID:-nekonoverse}
      S3_SECRET_ACCESS_KEY: ${S3_SECRET_ACCESS_KEY}
      S3_STORAGE_PATH: /data
      S3_REGION: us-east-1
      S3_XATTR_JCLOUDS_COMPAT: "true"
    volumes:
      - nekono3s_data:/data
    healthcheck:
      test: ["CMD", "python", "-c", "import socket; s=socket.create_connection(('localhost',8080),2); s.close()"]
      interval: 10s
      timeout: 5s
      retries: 3

  s3proxy-deliverer:
    image: ghcr.io/nananek/s3proxy-deliverer:latest
    restart: unless-stopped
    environment:
      STORAGE_ROOT: /data
    volumes:
      - nekono3s_data:/data:ro
    depends_on:
      nekono3s:
        condition: service_healthy

  app:
    image: ghcr.io/nananek/nekonoverse-backend:latest
    restart: unless-stopped
    command: >
      sh -c "alembic upgrade head && uvicorn app.main:app --host 0.0.0.0 --port 8000 --workers 4"
    environment:
      DATABASE_URL: postgresql+asyncpg://nekonoverse:${DB_PASSWORD}@postgresql:5432/nekonoverse
      VALKEY_URL: valkey://valkey:6379/0
      DOMAIN: ${DOMAIN}
      SECRET_KEY: ${SECRET_KEY}
      DEBUG: "false"
      S3_ENDPOINT_URL: http://nekono3s:8080
      S3_ACCESS_KEY_ID: ${S3_ACCESS_KEY_ID:-nekonoverse}
      S3_SECRET_ACCESS_KEY: ${S3_SECRET_ACCESS_KEY}
      S3_BUCKET: ${S3_BUCKET:-nekonoverse}
      S3_REGION: us-east-1
    expose:
      - "8000"
    depends_on:
      postgresql:
        condition: service_healthy
      valkey:
        condition: service_healthy
      nekono3s:
        condition: service_healthy

  worker:
    image: ghcr.io/nananek/nekonoverse-backend:latest
    restart: unless-stopped
    command: python -m app.worker.main
    environment:
      DATABASE_URL: postgresql+asyncpg://nekonoverse:${DB_PASSWORD}@postgresql:5432/nekonoverse
      VALKEY_URL: valkey://valkey:6379/0
      DOMAIN: ${DOMAIN}
      SECRET_KEY: ${SECRET_KEY}
      S3_ENDPOINT_URL: http://nekono3s:8080
      S3_ACCESS_KEY_ID: ${S3_ACCESS_KEY_ID:-nekonoverse}
      S3_SECRET_ACCESS_KEY: ${S3_SECRET_ACCESS_KEY}
      S3_BUCKET: ${S3_BUCKET:-nekonoverse}
      S3_REGION: us-east-1
    depends_on:
      postgresql:
        condition: service_healthy
      valkey:
        condition: service_healthy
      nekono3s:
        condition: service_healthy

  frontend:
    image: ghcr.io/nananek/nekonoverse-frontend:latest
    restart: unless-stopped
    expose:
      - "3000"

  nginx:
    image: nginx:alpine
    restart: unless-stopped
    volumes:
      - ./nginx.conf:/etc/nginx/nginx.conf:ro
      - /etc/letsencrypt:/etc/letsencrypt:ro
    ports:
      - "80:80"
      - "443:443"
    depends_on:
      - app
      - frontend

volumes:
  postgresql_data:
  valkey_data:
  nekono3s_data:
