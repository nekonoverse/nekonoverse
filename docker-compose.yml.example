# TCP ベースの簡易構成例。
# 本番環境では docker-compose.prod.yml (UDS + 静的フロントエンド配信) を推奨。
services:
  postgresql:
    image: postgres:18-alpine
    restart: unless-stopped
    environment:
      POSTGRES_DB: nekonoverse
      POSTGRES_USER: nekonoverse
      POSTGRES_PASSWORD: ${DB_PASSWORD}
    volumes:
      - ./volumes/postgresql:/var/lib/postgresql
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U nekonoverse"]
      interval: 10s
      timeout: 5s
      retries: 5

  valkey:
    image: valkey/valkey:8-alpine
    restart: unless-stopped
    volumes:
      - ./volumes/valkey:/data
    healthcheck:
      test: ["CMD", "valkey-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5

  nekono3s:
    image: ghcr.io/nananek/nekono3s:latest
    restart: unless-stopped
    environment:
      S3_ACCESS_KEY_ID: ${S3_ACCESS_KEY_ID:-nekonoverse}
      S3_SECRET_ACCESS_KEY: ${S3_SECRET_ACCESS_KEY}
      S3_STORAGE_PATH: /data
      S3_REGION: us-east-1
      S3_XATTR_JCLOUDS_COMPAT: "true"
    volumes:
      - ./volumes/nekono3s:/data
    healthcheck:
      test: ["CMD", "python", "-c", "import socket; s=socket.create_connection(('localhost',8080),2); s.close()"]
      interval: 10s
      timeout: 5s
      retries: 3

  s3proxy-deliverer:
    image: ghcr.io/nananek/s3proxy-deliverer:latest
    restart: unless-stopped
    environment:
      STORAGE_ROOT: /data
    volumes:
      - ./volumes/nekono3s:/data:ro
      - s3proxy_sock:/var/run/s3proxy-deliverer
    depends_on:
      nekono3s:
        condition: service_healthy

  app:
    # image: ghcr.io/nekonoverse/nekonoverse-backend:unstable
    image: ghcr.io/nekonoverse/nekonoverse-backend:latest
    restart: unless-stopped
    command: >
      sh -c "alembic upgrade head && python -m scripts.check_schema && uvicorn app.main:app --host 0.0.0.0 --port 8000 --workers 4"
    environment:
      DATABASE_URL: postgresql+asyncpg://nekonoverse:${DB_PASSWORD}@postgresql:5432/nekonoverse
      VALKEY_URL: valkey://valkey:6379/0
      DOMAIN: ${DOMAIN}
      SECRET_KEY: ${SECRET_KEY}
      FRONTEND_URL: https://${DOMAIN}
      DEBUG: "false"
      S3_ENDPOINT_URL: http://nekono3s:8080
      S3_ACCESS_KEY_ID: ${S3_ACCESS_KEY_ID:-nekonoverse}
      S3_SECRET_ACCESS_KEY: ${S3_SECRET_ACCESS_KEY}
      S3_BUCKET: ${S3_BUCKET:-nekonoverse}
      S3_REGION: us-east-1
      # face-detect (optional — set in .env)
      FACE_DETECT_URL: ${FACE_DETECT_URL:-}
      # media-proxy-transform (optional — set in .env)
      MEDIA_PROXY_TRANSFORM_URL: ${MEDIA_PROXY_TRANSFORM_URL:-}
      # summary-proxy (optional — set in .env)
      SUMMARY_PROXY_URL: ${SUMMARY_PROXY_URL:-}
      # Cloudflare Turnstile CAPTCHA (optional — set in .env)
      TURNSTILE_SITE_KEY: ${TURNSTILE_SITE_KEY:-}
      TURNSTILE_SECRET_KEY: ${TURNSTILE_SECRET_KEY:-}
      # Forward proxy for outbound federation requests (origin IP concealment)
      HTTP_PROXY: ${HTTP_PROXY:-}
      HTTPS_PROXY: ${HTTPS_PROXY:-}
      NO_PROXY: ${NO_PROXY:-nekono3s,valkey,postgresql,face-detect,media-proxy-transform,summary-proxy,localhost}
    expose:
      - "8000"
    depends_on:
      postgresql:
        condition: service_healthy
      valkey:
        condition: service_healthy
      nekono3s:
        condition: service_healthy

  worker:
    # image: ghcr.io/nekonoverse/nekonoverse-backend:unstable
    image: ghcr.io/nekonoverse/nekonoverse-backend:latest
    restart: unless-stopped
    command: python -m app.worker.main
    environment:
      DATABASE_URL: postgresql+asyncpg://nekonoverse:${DB_PASSWORD}@postgresql:5432/nekonoverse
      VALKEY_URL: valkey://valkey:6379/0
      DOMAIN: ${DOMAIN}
      SECRET_KEY: ${SECRET_KEY}
      S3_ENDPOINT_URL: http://nekono3s:8080
      S3_ACCESS_KEY_ID: ${S3_ACCESS_KEY_ID:-nekonoverse}
      S3_SECRET_ACCESS_KEY: ${S3_SECRET_ACCESS_KEY}
      S3_BUCKET: ${S3_BUCKET:-nekonoverse}
      S3_REGION: us-east-1
      # face-detect (optional — set in .env)
      FACE_DETECT_URL: ${FACE_DETECT_URL:-}
      # media-proxy-transform (optional — set in .env)
      MEDIA_PROXY_TRANSFORM_URL: ${MEDIA_PROXY_TRANSFORM_URL:-}
      # summary-proxy (optional — set in .env)
      SUMMARY_PROXY_URL: ${SUMMARY_PROXY_URL:-}
      # Forward proxy for outbound federation requests (origin IP concealment)
      HTTP_PROXY: ${HTTP_PROXY:-}
      HTTPS_PROXY: ${HTTPS_PROXY:-}
      NO_PROXY: ${NO_PROXY:-nekono3s,valkey,postgresql,face-detect,media-proxy-transform,summary-proxy,localhost}
    depends_on:
      postgresql:
        condition: service_healthy
      valkey:
        condition: service_healthy
      nekono3s:
        condition: service_healthy

  frontend:
    # image: ghcr.io/nekonoverse/nekonoverse-frontend:unstable
    image: ghcr.io/nekonoverse/nekonoverse-frontend:latest
    restart: unless-stopped
    expose:
      - "3000"

  nginx:
    image: nginx:alpine
    restart: unless-stopped
    volumes:
      - ./nginx/nginx.conf:/etc/nginx/conf.d/default.conf:ro
      - s3proxy_sock:/var/run/s3proxy-deliverer
    ports:
      - "80:80"
    depends_on:
      - app
      - frontend
      - s3proxy-deliverer

  # Optional: GPU face detection service (uncomment to use)
  # Requires NVIDIA GPU + nvidia-container-toolkit.
  # Set FACE_DETECT_URL=http://face-detect:8001/object-detection in app environment.
  # If running on a separate machine, set FACE_DETECT_URL to that machine's URL instead.
  # face-detect:
  #   build: ./face-detect
  #   restart: unless-stopped
  #   deploy:
  #     resources:
  #       reservations:
  #         devices:
  #           - driver: nvidia
  #             count: 1
  #             capabilities: [gpu]
  #   expose:
  #     - "8001"

  # Optional: Media proxy transform service (uncomment to use)
  # Provides thumbnail generation and WebP/PNG conversion for proxied media.
  # Set MEDIA_PROXY_TRANSFORM_URL=http://media-proxy-transform:8002 in app environment.
  # media-proxy-transform:
  #   build: ./media-proxy-transform
  #   restart: unless-stopped
  #   expose:
  #     - "8002"

  # Optional: URL summary proxy for link preview cards (uncomment to use)
  # Set SUMMARY_PROXY_URL=http://summary-proxy:8003 in app/worker environment.
  # summary-proxy:
  #   build: ./summary-proxy
  #   restart: unless-stopped
  #   expose:
  #     - "8003"

  # Optional: Cloudflare Tunnel (uncomment to use)
  # cloudflared:
  #   image: cloudflare/cloudflared:latest
  #   restart: unless-stopped
  #   command: tunnel run --token ${CLOUDFLARE_TUNNEL_TOKEN}
  #   environment:
  #     TUNNEL_TRANSPORT_PROTOCOL: http2

volumes:
  s3proxy_sock:
