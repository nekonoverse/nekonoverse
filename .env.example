# =============================================================================
# Nekonoverse - Environment Variables
# =============================================================================
# cp .env.example .env
#
# Commented-out variables are optional. Uncomment and edit to override defaults.
# =============================================================================

# --- Required ----------------------------------------------------------------

DB_PASSWORD=changeme
DOMAIN=localhost
SECRET_KEY=change-this-to-a-random-secret-key
FRONTEND_URL=http://localhost:3000

# --- S3 Storage (required) ---------------------------------------------------

S3_ACCESS_KEY_ID=nekonoverse
S3_SECRET_ACCESS_KEY=changeme-s3
S3_BUCKET=nekonoverse
# S3_ENDPOINT_URL=http://nekono3s:8080
# S3_REGION=us-east-1

# --- General -----------------------------------------------------------------

# DEBUG=false

# --- Database / Cache --------------------------------------------------------
# Docker Compose sets these automatically. Override only for custom setups.

# DATABASE_URL=postgresql+asyncpg://nekonoverse:changeme@localhost:5432/nekonoverse
# VALKEY_URL=valkey://localhost:6379/0
# VALKEY_MAX_CONNECTIONS=1000

# --- Face Detection (optional) -----------------------------------------------
# UDS (same machine):
#   FACE_DETECT_URL=http://localhost/object-detection
#   FACE_DETECT_UDS=/var/run/nekonoverse-face-detect/uvicorn.sock
# TCP (remote machine):
#   FACE_DETECT_URL=http://gpu-server:8001/object-detection

# --- neko-vision (optional) --------------------------------------------------
# Ollama連携画像自動タグ付けサービス。
# UDS (same machine):
#   NEKO_VISION_URL=http://localhost
#   NEKO_VISION_UDS=/var/run/neko-vision/uvicorn.sock
# TCP (remote machine):
#   NEKO_VISION_URL=http://neko-vision:8004

# --- Forward Proxy (optional) ------------------------------------------------
# HTTP_PROXY=http://squid:3128
# HTTPS_PROXY=http://squid:3128
# NO_PROXY=nekono3s,face-detect,neko-vision,localhost

# --- SMTP (optional) ---------------------------------------------------------
# Enables email verification and password reset when configured.
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USER=resend
# SMTP_PASSWORD=re_xxxxxxxxxxxx
# SMTP_FROM=noreply@yourdomain.com
# SMTP_SECURITY=ssl
#
# SMTP_SECURITY options:
#   starttls  — STARTTLS on port 587 (default)
#   ssl       — Implicit TLS on port 465 (Resend, SES, etc.)
#   none      — No encryption (not recommended)

# --- Cloudflare Turnstile CAPTCHA (optional) ---------------------------------
# TURNSTILE_SITE_KEY=0x...
# TURNSTILE_SECRET_KEY=0x...

# --- SSL ---------------------------------------------------------------------
# Skip TLS certificate verification for outbound requests (development only).
# SKIP_SSL_VERIFY=false
