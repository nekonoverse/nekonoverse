{
  "bind_addr": "/var/run/media-proxy-rs/media-proxy-rs.sock",
  "timeout": 10000,
  "user_agent": "Nekonoverse media-proxy-rs",
  "max_size": 268435456,
  "proxy": null,
  "filter_type": "Triangle",
  "max_pixels": 2048,
  "append_headers": [
    "Content-Security-Policy:default-src 'none'; img-src 'self'; media-src 'self'; style-src 'unsafe-inline'",
    "Access-Control-Allow-Origin:*"
  ],
  "load_system_fonts": true,
  "webp_quality": 80.0,
  "encode_avif": false,
  "enable_transform": true,
  "variant_sizes": {
    "avatar":  { "width": null, "height": 144 },
    "emoji":   { "width": null, "height": 96  },
    "preview": { "width": 800,  "height": 600 },
    "badge":   { "width": 96,   "height": 96  },
    "static":  { "width": null, "height": 144 }
  }
}
